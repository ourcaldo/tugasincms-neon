# Database Configuration (Neon PostgreSQL)
PGHOST=your-neon-host.neon.tech
PGDATABASE=your-database-name
PGUSER=your-database-user
PGPASSWORD=your-database-password
PGSSLMODE=require
PGCHANNELBINDING=require

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-clerk-publishable-key
CLERK_SECRET_KEY=sk_test_your-clerk-secret-key
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL=/posts
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=/posts

# Clerk Webhook (for user sync — get from Clerk Dashboard → Webhooks)
CLERK_WEBHOOK_SECRET=whsec_your-webhook-signing-secret

# Appwrite Storage
NEXT_PUBLIC_APPWRITE_PROJECT_ID=your-appwrite-project-id
NEXT_PUBLIC_APPWRITE_PROJECT_NAME=your-project-name
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
NEXT_PUBLIC_BUCKET_NAME=your-bucket-name
NEXT_PUBLIC_BUCKET_ID=your-bucket-id

# Redis Cache (Optional)
REDIS_HOST=your-redis-host
REDIS_PORT=6379
REDIS_USER=default
REDIS_PASSWORD=your-redis-password
REDIS_URL=redis://default:your-redis-password@your-redis-host:6379

# CMS Configuration
# CMS_HOST = where this CMS app is hosted (for sitemap index XML references)
# SITEMAP_HOST = the public frontend domain (for content URLs in sitemaps)
CMS_HOST=cms.nexjob.tech
SITEMAP_HOST=nexjob.tech

# Site URL (used in robots.txt, SEO previews, and fallback redirects)
NEXT_PUBLIC_SITE_URL=https://nexjob.tech

# Clerk Account Management URL (opens when user clicks "Manage Profile")
NEXT_PUBLIC_CLERK_ACCOUNT_URL=https://accounts.clerk.dev/user

# Security
# Comma-separated list of allowed origins for CORS
# REQUIRED in production — wildcard (*) is rejected in production
# Example: https://nexjob.tech,https://www.nexjob.tech,https://cms.nexjob.tech
ALLOWED_ORIGINS=https://nexjob.tech,https://www.nexjob.tech

# Rate Limiting (uses existing Redis from REDIS_URL above)
# Number of requests allowed per window
RATE_LIMIT_REQUESTS=100
# Window duration in seconds
RATE_LIMIT_WINDOW_SECONDS=60